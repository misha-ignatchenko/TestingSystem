<Window x:Class="LoadTestingSystem.Desktop.Views.AddLoadTestResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadTestingSystem.Desktop.Views"
        mc:Ignorable="d"
        Title="AddLoadTestResultWindow" Height="450" Width="800">
    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
               Grid.Column="1"
               Text="Додати результат"
               FontSize="24"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,0,15">
            <TextBlock Text="Назва тесту"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                Grid.Column="1"
                Margin="0,0,0,15">
            <TextBlock Text="RPS"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="RPSTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                Grid.Column="1"
                Margin="0,0,0,15">
            <TextBlock Text="Середній час"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="AvgTimeTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                Grid.Column="1"
                Margin="0,0,0,25">
            <TextBlock Text="Помилки"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="ErrorsCountTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="5"
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center">

            <Button x:Name="SaveButton"
                Width="120"
                Height="35"
                Margin="0,0,15,0"
                Content="Зберегти"
                Click="SaveButton_Click"/>

            <Button Width="120"
                Height="35"
                Content="Скасувати"
                Click="CancelButton_Click"/>

        </StackPanel>

    </Grid>
</Window>
